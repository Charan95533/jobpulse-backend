# ╔═══════════════════════════════════════════════════════════╗
# ║              JobPulse Configuration                       ║
# ║     Copy this to .env and fill in your credentials        ║
# ╚═══════════════════════════════════════════════════════════╝

# ── App Settings ──
SECRET_KEY=your-secret-key-change-me
DEBUG=true
PORT=5000

# ── Database ──
DATABASE_PATH=jobpulse.db

# ── Your Info ──
USER_EMAIL=agrcharanhrc@gmail.com
USER_NAME=Charan Adika

# ── Alert Settings ──
ALERT_FREQUENCY=instant          # instant | daily | weekly
MIN_MATCH_SCORE=70               # Minimum % to trigger alert
SCAN_INTERVAL_MINUTES=30         # How often to scan (in minutes)

# ── Email Provider ──
# Choose one: "smtp" | "sendgrid" | "ses"
EMAIL_PROVIDER=smtp

# ── Option 1: Gmail SMTP (Easiest — free) ──
# Step 1: Enable 2FA on your Google account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create an "App Password" for "Mail"
# Step 4: Paste the 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=agrcharanhrc@gmail.com
SMTP_PASSWORD=aixlgdnfqlaqzwcb
SMTP_FROM_NAME=JobPulse Alerts

# ── Option 2: SendGrid (Free tier: 100 emails/day) ──
# Sign up at https://sendgrid.com
# Create an API key at https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# ── Option 3: AWS SES (Cheapest at scale) ──
# Set up SES in AWS Console: https://console.aws.amazon.com/ses
# Verify your email address first
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SES_FROM_EMAIL=alerts@yourdomain.com

# ── Optional: Google Jobs via SerpAPI ──
# Sign up at https://serpapi.com (100 free searches/month)
# SERPAPI_KEY=your-serpapi-key
